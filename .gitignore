# Security & Credentials
.env

# Application State & Databases
tracked_items.json
messages_to_delete.json
subscribers.json
known_urls.json
searches.tracked

# User Configuration (Optional: remove if you want to share your searches)
searches.json

# Legacy Original Script Files
telegram_api_credentials
telegram-send.conf
ntfy_config

# Python Standard Ignores
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environments
venv/
.venv/
env/
ENV/